# ── RingEX / RingCentral ──────────────────────────────────────────────────────
# Get Client ID + Secret from: https://developers.ringcentral.com → your app → Credentials
RINGEX_CLIENT_ID=fF7Y1eyWSabbtCQKOsM3e1
RINGEX_CLIENT_SECRET=your_client_secret_here

# Sandbox: https://platform.devtest.ringcentral.com
# Production: https://platform.ringcentral.com
RINGEX_SERVER_URL=https://platform.ringcentral.com

# Bot JWT — from RingCentral app → Bot → JWT (generate in the app dashboard)
# This is DIFFERENT from the Client ID/Secret — it's a bot identity token
RINGEX_BOT_JWT=your_bot_jwt_here

# Random secret YOU pick — used to validate HMAC-SHA256 signatures on incoming webhooks
# Generate with: openssl rand -hex 32
RINGEX_WEBHOOK_SECRET=change_me_to_a_random_secret

# Public HTTPS URL of this server — RingCentral sends webhook events here
# Dev: ngrok tunnel URL (npm run dev:ngrok → copy the https://*.ngrok.io URL)
# Prod: your domain, e.g. https://ringtalk.your-domain.com
RINGEX_WEBHOOK_URL=https://your-ngrok-url.ngrok.io

# ── Hermes Agent Runtime ───────────────────────────────────────────────────────
# Local Hermes gateway (default for @research-agent)
HERMES_URL=http://localhost:2222
HERMES_API_KEY=

# ── OpenAI Codex CLI ─────────────────────────────────────────────────────────
# Used by @coding-agent — get from https://platform.openai.com/api-keys
CODEX_API_KEY=sk-...

# ── App Config ────────────────────────────────────────────────────────────────
LOG_LEVEL=info          # debug | info | warn | error
SESSION_TTL_DAYS=7      # sessions expire after this many days of inactivity
PORT=3000
NODE_ENV=development    # development | production
