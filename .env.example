# ── RingEX / RingCentral ──────────────────────────────────────────────────────
# Get these from: https://developers.ringcentral.com → Your App → Credentials
RINGEX_CLIENT_ID=your_client_id_here
RINGEX_CLIENT_SECRET=your_client_secret_here

# Sandbox or production
# Sandbox: https://platform.devtest.ringcentral.com
# Production: https://platform.ringcentral.com
RINGEX_SERVER_URL=https://platform.devtest.ringcentral.com

# Bot JWT — from RingCentral app → Bot → JWT
RINGEX_BOT_JWT=your_bot_jwt_here

# Webhook HMAC secret — set this yourself, used to validate incoming webhooks
RINGEX_WEBHOOK_SECRET=change_me_to_a_random_secret

# The public URL of this server — used to register the webhook with RingCentral
# Dev: use ngrok tunnel URL (e.g. https://abc123.ngrok.io)
# Prod: your domain (e.g. https://ringtalk.your-domain.com)
RINGEX_WEBHOOK_URL=https://your-ngrok-url.ngrok.io

# ── Hermes Agent Runtime ───────────────────────────────────────────────────────
# Local Hermes gateway (default for research-agent)
HERMES_URL=http://localhost:2222
HERMES_API_KEY=

# ── OpenAI Codex CLI ─────────────────────────────────────────────────────────
# Used by coding-agent
CODEX_API_KEY=sk-...

# ── App Config ────────────────────────────────────────────────────────────────
LOG_LEVEL=info
SESSION_TTL_DAYS=7
PORT=3000
NODE_ENV=development
