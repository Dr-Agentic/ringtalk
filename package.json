{
  "name": "ringtalk",
  "version": "0.1.0",
  "description": "RingTalk — AI agents as native RingEX teammates. @mention an agent, get expert-level work done in the same thread.",
  "license": "MIT",
  "type": "module",
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "dev:ngrok": "ngrok http 3000 --config=ngrok.yml & tsx watch src/index.ts",
    "dev:docker": "docker build -t ringtalk:local .",
    "build": "tsc",
    "start": "node dist/index.js",
    "lint": "eslint src",
    "test": "vitest",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@ringcentral/sdk": "^4.5.0",
    "express": "^4.19.2",
    "dotenv": "^16.4.5",
    "zod": "^3.23.8",
    "winston": "^3.14.2",
    "crypto-js": "^4.2.0"
  },
  "devDependencies": {
    "@types/express": "^4.17.21",
    "@types/node": "^22.5.0",
    "@types/crypto-js": "^4.2.2",
    "typescript": "^5.5.4",
    "tsx": "^4.19.0",
    "vitest": "^2.0.5",
    "@typescript-eslint/eslint-plugin": "^8.2.0",
    "@typescript-eslint/parser": "^8.2.0",
    "eslint": "^8.57.0"
  }
}
